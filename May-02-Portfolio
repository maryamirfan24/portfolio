<script>
const bg = document.getElementById('springBg');
const shapes = [
  // sunflower petals
  () => { const d = document.createElement('div'); d.style.cssText=`width:12px;height:12px;background:radial-gradient(circle,#f9c846,#e8a020);border-radius:50% 50% 50% 0;`; return d; },
  // tulip petal
  () => { const d = document.createElement('div'); d.style.cssText=`width:8px;height:14px;background:#c0392b;border-radius:50% 50% 50% 50%/60% 60% 40% 40%;`; return d; },
  // small circle
  () => { const d = document.createElement('div'); d.style.cssText=`width:7px;height:7px;background:#e8734a;border-radius:50%;`; return d; },
  // leaf
  () => { const d = document.createElement('div'); d.style.cssText=`width:10px;height:6px;background:#4a7c59;border-radius:50% 50% 50% 0;`; return d; },
];
for(let i=0;i<28;i++){
  const wrap = document.createElement('div');
  const inner = shapes[Math.floor(Math.random()*shapes.length)]();
  wrap.appendChild(inner);
  wrap.className = 'petal';
  wrap.style.left = Math.random()*100+'%';
  wrap.style.top = '-30px';
  wrap.style.animationDuration = (8+Math.random()*14)+'s';
  wrap.style.animationDelay = (Math.random()*12)+'s';
  bg.appendChild(wrap);
}
</script>
