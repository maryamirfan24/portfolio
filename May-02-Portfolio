<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1a1a;--muted:#555;--hint:#888;
  --surface:#fefdf9;--raised:#fff;
  --border:#e8e2d8;--border2:#ccc5b5;
  --accent:#c0392b;--accent2:#e8734a;
  --green:#4a7c59;--gold:#d4a843;
  --bg-warm:#fdf8f0;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--surface);color:var(--ink);overflow-x:hidden}
 
/* ── SPRING BACKGROUND ── */
.spring-bg{
  position:fixed;top:0;left:0;width:100%;height:100%;
  pointer-events:none;z-index:0;overflow:hidden;
}
.petal{position:absolute;opacity:0;animation:fall linear infinite}
@keyframes fall{
  0%{transform:translateY(-60px) rotate(0deg);opacity:0}
  10%{opacity:0.7}
  90%{opacity:0.4}
  100%{transform:translateY(110vh) rotate(720deg) translateX(60px);opacity:0}
}
/* SVG flowers in background - static */
.bg-flower{position:fixed;pointer-events:none;z-index:0;opacity:0.07}
 
/* ── LAYOUT ── */
.wrap{max-width:900px;margin:0 auto;padding:0 1.5rem 5rem;position:relative;z-index:1}
 
/* ── HERO ── */
.hero{padding:3.5rem 0 2.5rem;display:grid;grid-template-columns:1fr auto;gap:3rem;align-items:center;border-bottom:1px solid var(--border);margin-bottom:3rem}
.hero-text h1{font-family:'Playfair Display',serif;font-size:3.8rem;line-height:1.05;font-weight:600;margin-bottom:1rem}
.hero-text h1 em{font-style:italic;color:var(--accent)}
.hero-text h1 span{display:block;font-size:2.2rem;color:var(--muted);font-weight:400}
.tagline{font-size:1rem;line-height:1.75;color:var(--muted);max-width:520px;font-weight:300;margin-bottom:1.25rem}
.tagline strong{color:var(--ink);font-weight:500}
.hero-links{display:flex;flex-wrap:wrap;gap:0.6rem;margin-top:0.5rem}
.hero-links a{font-size:0.8rem;font-weight:500;letter-spacing:0.04em;padding:7px 16px;border-radius:20px;text-decoration:none;transition:all 0.2s}
.hero-links a.pill-solid{background:var(--accent);color:white;border:1.5px solid var(--accent)}
.hero-links a.pill-solid:hover{background:#a93226}
.hero-links a.pill-outline{border:1.5px solid var(--border2);color:var(--muted)}
.hero-links a.pill-outline:hover{border-color:var(--accent);color:var(--accent)}
.locations{font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--hint);margin-bottom:1rem;font-weight:500}
 
/* photo */
.photo-wrap{flex-shrink:0}
.photo-frame{
  width:220px;height:270px;border-radius:40% 60% 55% 45%/45% 50% 50% 55%;
  overflow:hidden;border:3px solid var(--border);
  box-shadow:8px 8px 0 var(--bg-warm),9px 9px 0 var(--border);
  position:relative;
}
.photo-frame img{width:100%;height:100%;object-fit:cover;object-position:center top}
.photo-flower{position:absolute;font-size:1.4rem;animation:bob 3s ease-in-out infinite}
.photo-flower.f1{top:-10px;right:-10px;animation-delay:0s}
.photo-flower.f2{bottom:-8px;left:-8px;animation-delay:1.5s}
@keyframes bob{0%,100%{transform:translateY(0) rotate(-5deg)}50%{transform:translateY(-6px) rotate(5deg)}}
 
/* ── KEYWORDS ── */
.kw-section{margin-bottom:3rem}
.section-label{font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;font-weight:500;color:var(--hint);margin-bottom:0.85rem}
.kw-bar{display:flex;flex-wrap:wrap;gap:0.45rem}
.kw{font-size:0.73rem;font-weight:500;padding:5px 13px;border-radius:20px;border:1px solid var(--border2);color:var(--muted);cursor:default;transition:all 0.2s;letter-spacing:0.03em}
.kw:hover{background:var(--accent);color:white;border-color:var(--accent);transform:translateY(-1px)}
.kw.hot{background:#fdf0ee;color:var(--accent);border-color:var(--accent)}
.kw.green{background:#f0f7f2;color:var(--green);border-color:var(--green)}
 
/* ── SECTIONS ── */
.section{margin-bottom:3.5rem}
hr.div{border:none;border-top:1px solid var(--border);margin:3rem 0}
 
/* ── CARDS ── */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
.card{
  background:var(--raised);border:1px solid var(--border);
  border-radius:14px;padding:1.3rem 1.4rem;
  transition:border-color 0.2s,transform 0.18s,box-shadow 0.18s;
  text-decoration:none;color:inherit;display:block;
}
.card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 8px 24px rgba(192,57,43,0.08)}
.card.accent-left{border-left:3px solid var(--accent)}
.card-eyebrow{font-size:0.67rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--accent);font-weight:500;margin-bottom:0.4rem}
.card-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:600;line-height:1.35;margin-bottom:0.5rem}
.card-body{font-size:0.81rem;color:var(--muted);line-height:1.65;font-weight:300}
.card-tags{display:flex;flex-wrap:wrap;gap:0.3rem;margin-top:0.8rem}
.tag{font-size:0.67rem;padding:3px 9px;border-radius:10px;background:var(--bg-warm);border:1px solid var(--border);color:var(--muted)}
.tag.h{background:#fdf0ee;color:var(--accent);border-color:var(--accent)}
.tag.g{background:#f0f7f2;color:var(--green);border-color:var(--green)}
 
/* ── FULL ROLE CARDS ── */
.role-card{background:var(--raised);border:1px solid var(--border);border-radius:14px;padding:1.4rem 1.5rem;margin-bottom:1rem}
.role-card:hover{border-color:var(--border2)}
.rh{display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.6rem}
.rt{font-weight:500;font-size:0.95rem}
.ro{font-size:0.82rem;color:var(--muted);font-style:italic}
.rd{font-size:0.74rem;color:var(--hint)}
.rb{font-size:0.81rem;color:var(--muted);line-height:1.7;font-weight:300;padding-left:1rem;margin-top:0.4rem}
.rb li{margin-bottom:0.25rem}
.rb li strong{color:var(--ink);font-weight:500}
 
/* ── SKILLS ── */
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:0.8rem}
.sg{background:var(--raised);border:1px solid var(--border);border-radius:10px;padding:1rem 1.1rem}
.sg-label{font-size:0.67rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);font-weight:500;margin-bottom:0.5rem}
.sg-list{font-size:0.8rem;color:var(--muted);line-height:1.9;font-weight:300}
 
/* ── EDU ── */
.edu-card{background:var(--raised);border:1px solid var(--border);border-radius:14px;padding:1.3rem 1.5rem;margin-bottom:0.85rem}
.edu-title{font-weight:500;font-size:0.92rem}
.edu-sub{font-size:0.79rem;color:var(--muted);font-weight:300;margin-top:0.25rem;line-height:1.6}
.badge{display:inline-block;font-size:0.67rem;background:#fdf0ee;color:var(--accent);border-radius:10px;padding:3px 9px;font-weight:500;margin-top:0.5rem}
.badge.g{background:#f0f7f2;color:var(--green)}
 
/* ── PERSONAL ── */
.personal-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.85rem}
.personal-card{padding:1.1rem 1.3rem;border:1px solid var(--border);border-radius:14px;background:var(--raised);transition:border-color 0.2s}
.personal-card:hover{border-color:var(--gold)}
.pt{font-size:0.82rem;font-weight:500;margin-bottom:0.3rem;display:flex;align-items:center;gap:0.4rem}
.pb{font-size:0.8rem;color:var(--muted);font-weight:300;line-height:1.6}
 
/* ── FOOTER ── */
footer{text-align:center;padding:2rem 0;font-size:0.78rem;color:var(--hint);border-top:1px solid var(--border)}
 
/* ── SUNFLOWER / TULIP SVGs ── */
.deco-sunflower,.deco-tulip{position:fixed;pointer-events:none;z-index:0;opacity:0.12}
 
@media(max-width:640px){
  .hero{grid-template-columns:1fr;gap:2rem}
  .photo-wrap{order:-1;display:flex;justify-content:center}
  .photo-frame{width:170px;height:210px}
  .hero-text h1{font-size:2.6rem}
  .hero-text h1 span{font-size:1.6rem}
  .grid-2,.grid-3,.personal-grid{grid-template-columns:1fr}
}
</style>
</head>
